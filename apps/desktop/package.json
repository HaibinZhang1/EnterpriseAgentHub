{
  "name": "@enterprise-agent-hub/desktop",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "npm run build --workspace @enterprise-agent-hub/shared-contracts && tsc --noEmit && vite build",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "tauri:build:windows": "tauri build --target x86_64-pc-windows-msvc --bundles nsis",
    "typecheck": "npm run build --workspace @enterprise-agent-hub/shared-contracts && tsc --noEmit",
    "lint": "node ./scripts/p1-ui-lint.mjs",
    "test": "npm run typecheck && node --experimental-strip-types --experimental-specifier-resolution=node --test test/*.test.ts"
  },
  "dependencies": {
    "@enterprise-agent-hub/shared-contracts": "0.1.0",
    "@vitejs/plugin-react": "6.0.1",
    "vite": "8.0.8",
    "typescript": "5.9.3",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "lucide-react": "1.8.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.2.7",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3"
  }
}
