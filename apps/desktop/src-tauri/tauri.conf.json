{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Enterprise Agent Hub",
  "version": "0.1.0",
  "identifier": "com.enterpriseagenthub.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Enterprise Agent Hub",
        "width": 1440,
        "height": 960,
        "minWidth": 1200,
        "minHeight": 780,
        "resizable": true,
        "decorations": false,
        "transparent": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/icon.ico",
      "icons/icon.png",
      "icons/icon.svg"
    ],
    "windows": {
      "nsis": {
        "displayLanguageSelector": true
      }
    }
  }
}
