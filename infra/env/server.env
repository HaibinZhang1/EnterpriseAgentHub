# EnterpriseAgentHub P1 server environment template.
# Copy to infra/env/server.env and adjust for the target intranet host.

API_PORT=3000
API_IMAGE=enterprise-agent-hub-api:0.1.0-p1
COMPOSE_PROJECT_NAME=enterprise-agent-hub
NODE_ENV=production
JWT_SECRET=change-me-before-deploy

POSTGRES_IMAGE=postgres:16.6-bookworm
POSTGRES_DB=enterprise_agent_hub
POSTGRES_USER=eah
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgresql://eah:change-me@postgres:5432/enterprise_agent_hub

REDIS_IMAGE=redis:7.4.1-bookworm
REDIS_URL=redis://redis:6379/0

MINIO_IMAGE=minio/minio:RELEASE.2024-12-18T13-15-44Z
MINIO_MC_IMAGE=minio/mc:RELEASE.2024-11-21T17-21-54Z
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=change-me-minio-secret
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change-me-minio-secret
MINIO_SKILL_PACKAGE_BUCKET=skill-packages
MINIO_SKILL_ASSET_BUCKET=skill-assets

NGINX_IMAGE=nginx:1.27.3-bookworm
NGINX_PORT=8080
OFFLINE_IMAGE_DIR=release/images
