{
  "name": "@enterprise-agent-hub/shared-contracts",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "P1 Desktop/API shared enums, DTOs, errors, pagination, and command contracts.",
  "main": "./dist/index.js",
